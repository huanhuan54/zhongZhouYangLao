<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.nursing.mapper.NursingProjectMapper">

    <resultMap type="NursingProject" id="NursingProjectResult">
        <id     property="id"                 column="id"                  />
        <result property="name"               column="name"                />
        <result property="projectCode"        column="project_code"        />
        <result property="projectType"        column="project_type"        />
        <result property="orderNo"            column="order_no"            />
        <result property="unit"               column="unit"                />
        <result property="price"              column="price"               />
        <result property="serviceDuration"    column="service_duration"    />
        <result property="image"              column="image"               />
        <result property="nursingRequirement" column="nursing_requirement" />
        <result property="status"             column="status"              />
        <result property="createBy"           column="create_by"           />
        <result property="createTime"         column="create_time"         />
        <result property="updateBy"           column="update_by"           />
        <result property="updateTime"         column="update_time"         />
        <result property="remark"             column="remark"              />
    </resultMap>

    <resultMap type="com.ruoyi.nursing.domain.vo.NursingProjectVo" id="NursingProjectVoResult">
        <result property="label" column="label" />
        <result property="value" column="value" />
    </resultMap>

    <sql id="selectNursingProjectVo">
        select id, name, project_code, project_type, order_no, unit, price, service_duration, image, nursing_requirement, status,
               create_by, create_time, update_by, update_time, remark
        from nursing_project
    </sql>

    <select id="selectNursingProjectList" parameterType="NursingProject" resultMap="NursingProjectResult">
        <include refid="selectNursingProjectVo"/>
        <where>
            <if test="name != null and name != ''">
                AND name like concat('%', #{name}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="projectType != null and projectType != ''">
                AND project_type = #{projectType}
            </if>
        </where>
        order by order_no asc, id asc
    </select>

    <select id="selectNursingProjectById" parameterType="Long" resultMap="NursingProjectResult">
        <include refid="selectNursingProjectVo"/>
        where id = #{id}
    </select>

    <select id="selectEnabledProjectOptions" resultMap="NursingProjectVoResult">
        select name as label, cast(id as char) as value
        from nursing_project
        where status = 1
        order by order_no asc, id asc
    </select>

    <insert id="insertNursingProject" parameterType="NursingProject" useGeneratedKeys="true" keyProperty="id">
        insert into nursing_project
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">name,</if>
            <if test="projectCode != null and projectCode != ''">project_code,</if>
            <if test="projectType != null and projectType != ''">project_type,</if>
            <if test="orderNo != null">order_no,</if>
            <if test="unit != null and unit != ''">unit,</if>
            <if test="price != null">price,</if>
            <if test="serviceDuration != null">service_duration,</if>
            <if test="image != null and image != ''">image,</if>
            <if test="nursingRequirement != null">nursing_requirement,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
            <if test="projectCode != null and projectCode != ''">#{projectCode},</if>
            <if test="projectType != null and projectType != ''">#{projectType},</if>
            <if test="orderNo != null">#{orderNo},</if>
            <if test="unit != null and unit != ''">#{unit},</if>
            <if test="price != null">#{price},</if>
            <if test="serviceDuration != null">#{serviceDuration},</if>
            <if test="image != null and image != ''">#{image},</if>
            <if test="nursingRequirement != null">#{nursingRequirement},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateNursingProject" parameterType="NursingProject">
        update nursing_project
        <set>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="projectCode != null">project_code = #{projectCode},</if>
            <if test="projectType != null">project_type = #{projectType},</if>
            <if test="orderNo != null">order_no = #{orderNo},</if>
            <if test="unit != null and unit != ''">unit = #{unit},</if>
            <if test="price != null">price = #{price},</if>
            <if test="serviceDuration != null">service_duration = #{serviceDuration},</if>
            <if test="image != null">image = #{image},</if>
            <if test="nursingRequirement != null">nursing_requirement = #{nursingRequirement},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteNursingProjectById" parameterType="Long">
        delete from nursing_project where id = #{id}
    </delete>
</mapper>
